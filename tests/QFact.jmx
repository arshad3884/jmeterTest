            <HTTPSamplerProxy guiclass="GraphQLHTTPSamplerGui" testclass="HTTPSamplerProxy" testname="Organisation" enabled="true">
              <stringProp name="HTTPSampler.domain">api.test.qfact.nl</stringProp>
              <stringProp name="HTTPSampler.port">443</stringProp>
              <stringProp name="HTTPSampler.contentEncoding">utf-8</stringProp>
              <stringProp name="HTTPSampler.path">/graphql</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
              <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="" elementType="HTTPArgument" enabled="true">
                    <boolProp name="HTTPArgument.always_encode">false</boolProp>
                    <stringProp name="Argument.value">{&quot;operationName&quot;:&quot;Organisation&quot;,&quot;variables&quot;:{&quot;organisationId&quot;:&quot;721f0e7b-bc0f-46a5-abca-1dcf20281df4&quot;},&quot;query&quot;:&quot;query Organisation($organisationId: String!) {\n  organisation(id: $organisationId) {\n    id\n    name\n    logo\n    type\n    address {\n      line1\n      line2\n      zip\n      city\n      country\n      __typename\n    }\n    status\n    phones {\n      phone\n      name\n      main\n      __typename\n    }\n    legal {\n      name\n      country\n      branchId\n      registrationId\n      __typename\n    }\n    products {\n      name\n      slug\n      enabled\n      modules\n      settings\n      __typename\n    }\n    users {\n      status\n      userId\n      roleId\n      role {\n        id\n        name\n        __typename\n      }\n      email\n      user {\n        id\n        email\n        firstName\n        lastName\n        avatar\n        __typename\n      }\n      __typename\n    }\n    childs {\n      id\n      name\n      type\n      address {\n        line1\n        line2\n        zip\n        city\n        country\n        __typename\n      }\n      legal {\n        registrationId\n        branchId\n        __typename\n      }\n      __typename\n    }\n    servicesAverage\n    worksAverage\n    mainConfigurationId\n    settings {\n      projectConfigurations\n      sso {\n        enabled\n        ssoRequired\n        __typename\n      }\n      __typename\n    }\n    __typename\n  }\n}&quot;}</stringProp>
                    <stringProp name="Argument.metadata">=</stringProp>
                    <boolProp name="HTTPArgument.use_equals">true</boolProp>
                  </elementProp>
                </collectionProp>
              </elementProp>
              <stringProp name="GraphQLHTTPSampler.operationName">Organisation</stringProp>
              <stringProp name="GraphQLHTTPSampler.query">query Organisation($organisationId: String!) {
  organisation(id: $organisationId) {
    id
    name
    logo
    type
    address {
      line1
      line2
      zip
      city
      country
      __typename
    }
    status
    phones {
      phone
      name
      main
      __typename
    }
    legal {
      name
      country
      branchId
      registrationId
      __typename
    }
    products {
      name
      slug
      enabled
      modules
      settings
      __typename
    }
    users {
      status
      userId
      roleId
      role {
        id
        name
        __typename
      }
      email
      user {
        id
        email
        firstName
        lastName
        avatar
        __typename
      }
      __typename
    }
    childs {
      id
      name
      type
      address {
        line1
        line2
        zip
        city
        country
        __typename
      }
      legal {
        registrationId
        branchId
        __typename
      }
      __typename
    }
    servicesAverage
    worksAverage
    mainConfigurationId
    settings {
      projectConfigurations
      sso {
        enabled
        ssoRequired
        __typename
      }
      __typename
    }
    __typename
  }
}
</stringProp>
