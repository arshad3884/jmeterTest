              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="" elementType="HTTPArgument" enabled="true">
                    <boolProp name="HTTPArgument.always_encode">false</boolProp>
                    <stringProp name="Argument.value">{&quot;operationName&quot;:&quot;Login&quot;,&quot;variables&quot;:{&quot;email&quot;:&quot;t.timmer@timmer.qfact&quot;,&quot;password&quot;:&quot;Test123!&quot;},&quot;query&quot;:&quot;mutation Login($email: String!, $password: String!) {\n  user_login(email: $email, password: $password) {\n    jwt\n    refreshToken\n    twofactorRequired\n    twofactorQRcode\n    user {\n      id\n      firstName\n      lastName\n      email\n      status\n      avatar\n      phone\n      changeEmail\n      __typename\n    }\n    __typename\n  }\n}&quot;}</stringProp>
                    <stringProp name="Argument.metadata">=</stringProp>
                    <boolProp name="HTTPArgument.use_equals">true</boolProp>
                  </elementProp>
                </collectionProp>
              </elementProp>
              <stringProp name="GraphQLHTTPSampler.operationName">Login</stringProp>
              <stringProp name="GraphQLHTTPSampler.query">mutation Login($email: String!, $password: String!) {
  user_login(email: $email, password: $password) {
    jwt
    refreshToken
    twofactorRequired
    twofactorQRcode
    user {
      id
      firstName
      lastName
      email
      status
      avatar
      phone
      changeEmail
      __typename
    }
    __typename
  }
}
</stringProp>
