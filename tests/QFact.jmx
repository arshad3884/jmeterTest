              <stringProp name="GraphQLHTTPSampler.query">query VendorlistGetClient($clientId: String!, $branchId: String) {
  vendorlist_getClient(clientId: $clientId, branchId: $branchId) {
    name
    status
    clientId
    isLegacy
    isPublic
    companyReviewScore {
      totalScore
      categories {
        title
        projects {
          name
          score
          __typename
        }
        __typename
      }
      __typename
    }
    statusChanges {
      userId
      vendorlistId
      comment
      branchId
      clientId
      timestamp
      userType
      clientName
      contractorName
      type
      oldStatus
      newStatus
      userName
      __typename
    }
    customDescriptions {
      title
      description
      type
      attachmentUrl
      __typename
    }
    subscriptions {
      vendorlistId
      branchId
      status
      areasOfInterestChoice {
        id
        referenceAmount
        __typename
      }
      statusChanges {
        userId
        vendorlistId
        comment
        branchId
        clientId
        timestamp
        userType
        clientName
        contractorName
        type
        oldStatus
        newStatus
        userName
        __typename
      }
      __typename
    }
    documentTemplates {
      hasReferenceAmount
      templateName
      templateId
      vendorlistId
      type
      description
      customDocumentsAllowed
      documents {
        fileName
        documentId
        documentName
        hasFile
        referenceAmount
        expirationDate
        maxDays
        skillId
        uploadDate
        hasReferenceAmount
        customDocument
        __typename
      }
      __typename
    }
    __typename
  }
}
</stringProp>
